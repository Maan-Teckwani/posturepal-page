# PosturePal website environment variables
# Copy to .env.local and fill in actual values.

# Download URLs used in the success page and license email
NEXT_PUBLIC_DOWNLOAD_URL_MAC=https://github.com/Maan-Teckwani/posturepal-releases/releases/latest/download/PosturePal.dmg
NEXT_PUBLIC_DOWNLOAD_URL_WIN=https://github.com/Maan-Teckwani/posturepal-releases/releases/latest/download/PosturePal-Setup.exe
NEXT_PUBLIC_DOWNLOAD_URL_LINUX=https://github.com/Maan-Teckwani/posturepal-releases/releases/latest/download/PosturePal.AppImage

DOWNLOAD_URL_MAC=https://github.com/Maan-Teckwani/posturepal-releases/releases/latest/download/PosturePal.dmg
DOWNLOAD_URL_WIN=https://github.com/Maan-Teckwani/posturepal-releases/releases/latest/download/PosturePal-Setup.exe
DOWNLOAD_URL_LINUX=https://github.com/Maan-Teckwani/posturepal-releases/releases/latest/download/PosturePal.AppImage

# Supabase (service role key required for license writes)
SUPABASE_URL=https://your-supabase-project-url.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Razorpay (public key used client-side, secret keys server-side only)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# Resend (for license delivery emails)
RESEND_API_KEY=re_...

# Web3Forms (Teams "register interest" form — public access key, safe client-side)
NEXT_PUBLIC_WEB3FORMS_KEY=your-web3forms-access-key
